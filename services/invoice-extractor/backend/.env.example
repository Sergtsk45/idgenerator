# Провайдер LLM: anthropic | openrouter | openai
LLM_PROVIDER=anthropic

# API ключи (заполните нужный)
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
OPENROUTER_API_KEY=sk-or-...

# Модели
ANTHROPIC_MODEL=claude-opus-4-5
OPENAI_MODEL=gpt-4o
OPENROUTER_MODEL=anthropic/claude-opus-4-5

# Настройки сервера
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=false

# CORS: разрешенные origins (через запятую)
ALLOWED_ORIGINS=http://localhost:8080

# Ограничения
MAX_FILE_SIZE_MB=50
MAX_PAGES=30
REQUEST_TIMEOUT_SEC=120

# Папки
UPLOAD_FOLDER=uploads
OUTPUT_FOLDER=outputs
